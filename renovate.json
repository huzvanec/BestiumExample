{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:automergeEarlyMondays"
  ],
  "dependencyDashboard": true,
  "automergeType": "branch",
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "groupName": "weekly minors",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ]
}
